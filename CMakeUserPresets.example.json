{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "qt6-macos",
      "inherits": "base",
      "displayName": "Qt 6.11 MacOS AppleClang (Ninja Multi-Config)",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "/usr/bin/c++",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo",
        "CMAKE_PREFIX_PATH": "$env{HOME}/Qt/6.11.1/macos",
        "CMAKE_MAKE_PROGRAM": "$env{HOME}/Qt/Tools/Ninja/ninja"
      },
      "vendor": {
        "qt.io/QtCreator/1.0": {
          "AskBeforePresetsReload": true,
          "AskReConfigureInitialParams": true,
          "AutorunCMake": false,
          "PackageManagerAutoSetup": false,
          "ShowAdvancedOptionsByDefault": true,
          "ShowSourceSubFolders": false,
          "UseJunctionsForSourceAndBuildDirectories": true
        }
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt6-macos-debug",
      "displayName": "Qt6 MacOS AppleClang - Debug",
      "configurePreset": "qt6-macos",
      "configuration": "Debug"
    },
    {
      "name": "qt6-macos-release",
      "displayName": "Qt6 MacOS AppleClang - Release",
      "configurePreset": "qt6-macos",
      "configuration": "Release"
    },
    {
      "name": "qt6-macos-relwithdebinfo",
      "displayName": "Qt6 MacOS AppleClang - RelWithDebInfo",
      "configurePreset": "qt6-macos",
      "configuration": "RelWithDebInfo"
    }
  ]
}