{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo",
        "CMAKE_PREFIX_PATH": "$env{QT_ROOT}/$env{QT_VERSION}/$env{QT_TOOLCHAIN}"
      }
    },
    {
      "name": "base-windows",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "$env{QT_ROOT}/Tools/Ninja/ninja.exe"
      },
      "environment": {
        "QT_ROOT": "C:/Qt",
        "QT_VERSION": "6.11.1"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "base-unix",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "$env{QT_ROOT}/Tools/Ninja/ninja"
      },
      "environment": {
        "QT_ROOT": "$env{HOME}/Qt",
        "QT_VERSION": "6.11.1"
      },
      "condition": {
        "type": "inList",
        "string": "${hostSystemName}",
        "list": [
          "Linux",
          "Darwin"
        ]
      }
    },
    {
      "name": "qt6-windows-msvc",
      "inherits": "base-windows",
      "displayName": "Qt 6.11.1 Windows MSVC 2026 x64 (Ninja Multi-Config)",
      "environment": {
        "QT_TOOLCHAIN": "msvc2022_64",
        "PATH": "$env{QT_ROOT}/$env{QT_VERSION}/$env{QT_TOOLCHAIN}/bin;$penv{PATH}",
        "CC": "cl.exe"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "toolset": {
        "value": "v145,host=x64",
        "strategy": "external"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "qt6-windows-mingw64",
      "inherits": "base-windows",
      "displayName": "Qt 6.11.1 Windows MinGW64 (Ninja Multi-Config)",
      "environment": {
        "QT_TOOLCHAIN": "mingw_64",
        "QT_TOOL_COMPILER": "mingw1310_64",
        "PATH": "$env{QT_ROOT}/Tools/$env{QT_TOOL_COMPILER}/bin;$env{QT_ROOT}/$env{QT_VERSION}/$env{QT_TOOLCHAIN}/bin;$penv{PATH}",
        "CC": "$env{QT_ROOT}/Tools/$env{QT_TOOL_COMPILER}/bin/gcc.exe"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "$env{QT_ROOT}/Tools/$env{QT_TOOL_COMPILER}/bin/g++.exe"
      }
    },
    {
      "name": "qt6-macos",
      "inherits": "base-unix",
      "displayName": "Qt 6.11.1 MacOS AppleClang (Ninja Multi-Config)",
      "environment": {
        "QT_TOOLCHAIN": "macos",
        "PATH": "$env{QT_ROOT}/$env{QT_VERSION}/$env{QT_TOOLCHAIN}/bin:$penv{PATH}",
        "CC": "clang"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "qt6-linux-gcc",
      "inherits": "base-unix",
      "displayName": "Qt 6.11.1 Linux GCC (Ninja Multi-Config)",
      "environment": {
        "QT_TOOLCHAIN": "gcc_64",
        "PATH": "$env{QT_ROOT}/$env{QT_VERSION}/$env{QT_TOOLCHAIN}/bin:$penv{PATH}",
        "CC": "gcc"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt6-windows-mingw64-debug",
      "displayName": "Qt6 Windows MinGW64 - Debug",
      "configurePreset": "qt6-windows-mingw64",
      "configuration": "Debug"
    },
    {
      "name": "qt6-windows-mingw64-release",
      "displayName": "Qt6 Windows MinGW64 - Release",
      "configurePreset": "qt6-windows-mingw64",
      "configuration": "Release"
    },
    {
      "name": "qt6-windows-mingw64-relwithdebinfo",
      "displayName": "Qt6 Windows MinGW64 - RelWithDebInfo",
      "configurePreset": "qt6-windows-mingw64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "qt6-windows-msvc-debug",
      "displayName": "Qt6 Windows MSVC 2026 x64 - Debug",
      "configurePreset": "qt6-windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "qt6-windows-msvc-release",
      "displayName": "Qt6 Windows MSVC 2026 x64 - Release",
      "configurePreset": "qt6-windows-msvc",
      "configuration": "Release"
    },
    {
      "name": "qt6-windows-msvc-relwithdebinfo",
      "displayName": "Qt6 Windows MSVC 2026 x64 - RelWithDebInfo",
      "configurePreset": "qt6-windows-msvc",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "qt6-macos-debug",
      "displayName": "Qt6 MacOS AppleClang - Debug",
      "configurePreset": "qt6-macos",
      "configuration": "Debug"
    },
    {
      "name": "qt6-macos-release",
      "displayName": "Qt6 MacOS AppleClang - Release",
      "configurePreset": "qt6-macos",
      "configuration": "Release"
    },
    {
      "name": "qt6-macos-relwithdebinfo",
      "displayName": "Qt6 MacOS AppleClang - RelWithDebInfo",
      "configurePreset": "qt6-macos",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "qt6-linux-gcc-debug",
      "displayName": "Qt6 Linux GCC - Debug",
      "configurePreset": "qt6-linux-gcc",
      "configuration": "Debug"
    },
    {
      "name": "qt6-linux-gcc-release",
      "displayName": "Qt6 Linux GCC - Release",
      "configurePreset": "qt6-linux-gcc",
      "configuration": "Release"
    },
    {
      "name": "qt6-linux-gcc-relwithdebinfo",
      "displayName": "Qt6 Linux GCC - RelWithDebInfo",
      "configurePreset": "qt6-linux-gcc",
      "configuration": "RelWithDebInfo"
    }
  ]
}
